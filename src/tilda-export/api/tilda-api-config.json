  "design_system": {
    "colors": {
      "brand_black": "#000000",
      "brand_white": "#FFFFFF",
      "brand_cream": "#F5F5DC",
      "brand_navy": "#1A1F3A",
      "brand_red": "#C41E3A",
      "brand_gold": "#D4AF37",
      "brand_gold_hover": "#B89520"
    },
    "typography": {
      "heading_font": "Georgia, 'Times New Roman', serif",
      "body_font": "system-ui, -apple-system, sans-serif",
      "sizes": {
        "hero": 96,
        "h1": 64,
        "h2": 48,
        "h3": 40,
        "h4": 24,
        "body_large": 20,
        "body": 16,
        "small": 14,
        "tiny": 12
      },
      "letter_spacing": {
        "tight": "-0.02em",
        "normal": "0",
        "wide": "0.05em",
        "wider": "0.1em",
        "widest": "0.2em"
      }
    },
    "spacing": {
      "container_max": 1280,
      "container_standard": 1200,
      "content_area": 1120,
      "padding_horizontal": 40,
      "padding_vertical": 80,
      "gap_small": 16,
      "gap_medium": 32,
      "gap_large": 48,
      "gap_xlarge": 64
    },
    "effects": {
      "border_radius": {
        "small": 4,
        "medium": 8,
        "large": 12,
        "full": 9999
      },
      "transitions": {
        "fast": "0.15s ease",
        "normal": "0.3s ease",
        "slow": "0.5s ease"
      }
    }
  },
  
  "tilda_api": {
    "version": "1.0",
    "endpoints": {
      "add_block": "https://api.tildacdn.info/v1/addblock",
      "update_block": "https://api.tildacdn.info/v1/updateblock",
      "get_page": "https://api.tildacdn.info/v1/getpage"
    },
    "required_params": [
      "publickey",
      "secretkey",
      "projectid",
      "pageid"
    ],
    "block_settings": {
      "width": 1200,
      "responsive": true,
      "mobile_breakpoint": 768,
      "tablet_breakpoint": 1024
    }
  },
  
  "export_checklist": {
    "images": [
      "Логотип (PNG, прозрачный, ~500×500px)",
      "Фоновое фото Hero (JPG, 1920×1080px, оптимизировано)",
      "Фото товаров (JPG, 600×800px, aspect 3:4, 6 шт минимум)"
