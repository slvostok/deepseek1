    "content": [
      "Тексты описаний товаров",
      "Цены товаров в рублях",
      "Email для контактов",
      "Ссылки на соцсети (Instagram, VK и др.)"
    ],
    "settings": [
      "API ключи Tilda (public + secret)",
      "ID проекта и страницы",
      "Проверка доступа к Zero Block"
    ]
  },
  
  "notes": {
    "important": [
      "Все фреймы имеют фиксированную ширину 1200px",
      "Внутренние отступы по 40px слева и справа (content area = 1120px)",
      "Все элементы выровнены по сетке",
      "Ширина текста = ширина шейпов = 1200px",
      "Используются точные расчеты для колонок и gap",
      "Все изображения оптимизированы (< 500KB)",
      "SVG иконки встроены inline для быстрой загрузки",
      "Hover эффекты добавлены для интерактивности",
      "Адаптивность настроена для мобильных устройств"
    ],
    "calculations": {
      "3_column_grid": "(1120 - gap×2) / 3 = column_width",
      "4_column_grid": "(1120 - gap×3) / 4 = column_width",
      "philosophy_columns": "(1120 - 48×2) / 3 = 341px ≈ 340px",
      "product_cards": "(1120 - 32×2) / 3 = 352px",
      "footer_columns": "(1120 - 40×3) / 4 = 260px"
    }
  }
